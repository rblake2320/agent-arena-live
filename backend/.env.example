# ── Required ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://arena:CHANGE_ME@localhost:55433/agent_arena

# Signing secret for JWTs. Generate with: openssl rand -hex 32
# The server refuses to start in production if this is < 32 chars.
JWT_SECRET=

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Comma-separated list of allowed browser origins
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# ── Optional (defaults shown) ───────────────────────────────
JWT_EXPIRES_IN=7d
WS_PATH=/socket.io
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20
RATING_K_FACTOR=32
LOG_LEVEL=info

# ── Seeding (npm run db:seed) ───────────────────────────────
# Password for the demo accounts; random per run if unset.
# SEED_PASSWORD=
# The seed wipes all data. In production it refuses to run unless:
# SEED_FORCE=true
